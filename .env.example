# PostHog Analytics (Website)
# Create a SEPARATE project in PostHog for website analytics (not the app project)
# Get the API key from: PostHog → Project Settings → Project API Key
VITE_POSTHOG_KEY=phc_your_project_api_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Meta (Facebook/Instagram) Pixel
# Get from: Meta Business Suite → Events Manager → Pixel → Settings
VITE_META_PIXEL_ID=

# Google Ads Conversion Tag
# Get from: Google Ads → Tools → Conversions → Tag setup
VITE_GOOGLE_ADS_ID=
# Optional: specific conversion label (format: XXXXXXXXXXXX)
VITE_GOOGLE_ADS_CONVERSION_LABEL=

# LinkedIn Insight Tag
# Get from: LinkedIn Campaign Manager → Analyze → Insight Tag
VITE_LINKEDIN_PARTNER_ID=

# RB2B Visitor Identification (free tier: 150 identifications/month)
# Get from: RB2B dashboard → Install → copy site ID
VITE_RB2B_SITE_ID=

# Apollo.io Website Tracker (visitor identification + CRM integration)
# Get from: Apollo → Settings → Website Tracker → copy App ID
VITE_APOLLO_APP_ID=
