# Cache-Control headers for static assets.
# Render serves these via its CDN (Cloudflare), which respects Cache-Control.

# Vite-fingerprinted assets (/assets/*) have content hashes in filenames —
# safe to cache forever since the filename changes on every build.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted font files — same-origin, rarely change.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Image assets in root — no content hash, so use a shorter TTL.
# 7 days is enough that repeat visitors won't re-download, but changes
# propagate within a week.
/*.webp
  Cache-Control: public, max-age=604800
/*.png
  Cache-Control: public, max-age=604800
/*.jpg
  Cache-Control: public, max-age=604800
